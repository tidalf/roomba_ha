  "config_flow": true,
  "dhcp": [
    {
      "hostname": "irobot-*",
      "macaddress": "501479*"
    },
    {
      "hostname": "roomba-*",
      "macaddress": "80A589*"
    },
    {
      "hostname": "roomba-*",
      "macaddress": "DCF505*"
    },
    {
      "hostname": "roomba-*",
      "macaddress": "204EF6*"
